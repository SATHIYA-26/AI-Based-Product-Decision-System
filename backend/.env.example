# Review Clustering System - Environment Variables Template

# ============================================
# DATABASE CONFIGURATION
# ============================================
# SQLite (Development)
DATABASE_URL=sqlite:///data/cluster_analysis.db

# PostgreSQL (Production)
# DATABASE_URL=postgresql://username:password@localhost:5432/review_clustering_db

# ============================================
# OPENAI CONFIGURATION (Optional)
# ============================================
# Set if using LLM features for summaries and labels
OPENAI_API_KEY=

# ============================================
# APPLICATION CONFIGURATION
# ============================================
FLASK_ENV=development
FLASK_PORT=5000
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-here

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ============================================
# SCHEDULER CONFIGURATION
# ============================================
# Interval in hours for automatic processing
SCHEDULER_INTERVAL=1

# ============================================
# TEXT PROCESSING CONFIGURATION
# ============================================
# Spacy model for NLP
SPACY_MODEL=en_core_web_sm

# Minimum review length (characters)
MIN_REVIEW_LENGTH=10

# ============================================
# CLUSTERING CONFIGURATION
# ============================================
# HDBSCAN minimum cluster size
CLUSTER_MIN_SIZE=5

# HDBSCAN minimum samples
CLUSTER_MIN_SAMPLES=3

# ============================================
# API INGESTION CONFIGURATION
# ============================================
# Default API endpoint (can be overridden per request)
API_ENDPOINT=

# Request timeout in seconds
API_TIMEOUT=30

# ============================================
# EMAIL CONFIGURATION (Optional)
# ============================================
MAIL_SERVER=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@example.com

# ============================================
# MONITORING & ERROR TRACKING (Optional)
# ============================================
# Sentry DSN for error tracking
SENTRY_DSN=

# ============================================
# CORS CONFIGURATION
# ============================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000

# ============================================
# FEATURE FLAGS
# ============================================
# Enable/disable features
ENABLE_TREND_ANALYSIS=true
ENABLE_LLM_SUMMARIES=true
ENABLE_AUTO_SCHEDULING=true
