# Review Clustering System - Environment Variables Template

# ============================================
# DATABASE CONFIGURATION
# ============================================
# SQLite (Development)
DATABASE_URL=sqlite:///data/cluster_analysis.db

# PostgreSQL (Production)
# DATABASE_URL=postgresql://username:password@localhost:5432/review_clustering_db

# ============================================
# OPENAI CONFIGURATION (Optional)
# ============================================
# Set if using LLM features for summaries and labels
OPENAI_API_KEY=

# ============================================
# APPLICATION CONFIGURATION
# ============================================
FLASK_ENV=development
FLASK_PORT=5000
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-here

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ============================================
# SCHEDULER CONFIGURATION
# ============================================
# Interval in hours for automatic processing
SCHEDULER_INTERVAL=1

# ============================================
# TEXT PROCESSING CONFIGURATION
# ============================================
# Spacy model for NLP
SPACY_MODEL=en_core_web_sm

# Minimum review length (characters)
MIN_REVIEW_LENGTH=10

# ============================================
# CLUSTERING CONFIGURATION
# ============================================
# HDBSCAN minimum cluster size
CLUSTER_MIN_SIZE=5

# HDBSCAN minimum samples
CLUSTER_MIN_SAMPLES=3

# ============================================
# API INGESTION CONFIGURATION
# ============================================
# Default API endpoint (can be overridden per request)
API_ENDPOINT=

# Request timeout in seconds
API_TIMEOUT=30

# ============================================
# EMAIL CONFIGURATION (Optional)
# ============================================
MAIL_SERVER=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@example.com

# ============================================
# MONITORING & ERROR TRACKING (Optional)
# ============================================
# Sentry DSN for error tracking
SENTRY_DSN=

# ============================================
# CORS CONFIGURATION
# ============================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000

# ============================================
# FEATURE FLAGS
# ============================================
# Enable/disable features
ENABLE_TREND_ANALYSIS=true
ENABLE_LLM_SUMMARIES=true
ENABLE_AUTO_SCHEDULING=true

# ============================================
# EXTERNAL CONNECTOR CONFIGURATION
# ============================================
# Google Play Store Configuration
GOOGLE_PLAY_APP_ID=com.example.yourapp
GOOGLE_PLAY_LANGUAGE=en
GOOGLE_PLAY_COUNTRY=us

# Apple App Store Configuration
APP_STORE_APP_ID=123456789
APP_STORE_COUNTRY=us

# Generic API Connector Configuration
CUSTOM_API_ENDPOINT=https://api.example.com/reviews
CUSTOM_API_KEY=your-api-key-here
CUSTOM_API_AUTH_TYPE=api_key

# ============================================
# AUTOMATED SYNC CONFIGURATION
# ============================================
# Default fetch limit per sync
SYNC_FETCH_LIMIT=100

# Default lookback period in days
SYNC_LOOKBACK_DAYS=7

# Maximum concurrent sync jobs
SYNC_MAX_CONCURRENT_JOBS=3

# Default sync interval in minutes
SYNC_DEFAULT_INTERVAL_MINUTES=60

# Execution window (only run between these hours)
SYNC_START_HOUR=8
SYNC_END_HOUR=22

